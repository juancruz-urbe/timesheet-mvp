# PostgreSQL
DB_USER=
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=

# Azure DevOps
AZURE_URL=
ACCESS_TOKEN=

# AWS
aws_access_key_id=
aws_secret_access_key=
serial_number=
clave_secreta_MFA=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# ETL cron schedule (formato crontab, default: todos los dias a las 20:00)
LOADER_CRON_SCHEDULE=0 20 * * *

# Puertos (opcionales, tienen defaults)
API_PORT=8000
FRONTEND_PORT=3000

# Frontend dev (solo para npm run dev local, no Docker)
VITE_DEV_API_URL=http://localhost:8000
